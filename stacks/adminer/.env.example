DOMAIN=<domain>
# Generate the hash on the server with:
#   openssl passwd -apr1 yourpassword
# Example output: $apr1$OKylGb66$DfmJfv9OK3IuyzrN04zr0.
#
# IMPORTANT: Every $ in the hash must be escaped as $$ when entering in Portainer.
# If your hash is:   admin:$apr1$abc$xyz
# Enter in Portainer: admin:$$apr1$$abc$$xyz
ADMINER_BASICAUTH_USERS=admin:$$apr1$$CHANGE_ME
