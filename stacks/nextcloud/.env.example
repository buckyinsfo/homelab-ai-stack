# Nextcloud stack — environment variables
# Copy relevant values to Portainer before deploying.
# Never commit real values to git.

DOMAIN=<domain>

# Postgres connection (must match the postgres stack values)
POSTGRES_USER=<db-user>
POSTGRES_PASSWORD=<db-password>
NEXTCLOUD_DB_NAME=nextcloud

# Nextcloud admin account (set on first boot only)
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=<strong-secret>

# PHP limits — tune to your storage/upload needs
NEXTCLOUD_PHP_MEMORY_LIMIT=512M
NEXTCLOUD_PHP_UPLOAD_LIMIT=512M
