{
  "meta": {
    "lastTouchedVersion": "2026.3.13",
    "lastTouchedAt": "2026-03-22T00:00:00.000Z"
  },
  "wizard": {
    "lastRunAt": "2026-03-05T18:01:23.657Z",
    "lastRunVersion": "2026.3.2",
    "lastRunCommand": "doctor",
    "lastRunMode": "local"
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "provider": "openrouter",
        "mode": "api_key"
      },
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      },
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "api_key"
      }
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://ollama:11434",
        "apiKey": "ollama-local",
        "api": "ollama",
        "models": [
          {
            "id": "llama3.2:latest",
            "name": "Llama 3.2 3B",
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 8192,
            "maxTokens": 4096
          },
          {
            "id": "mistral:7b-instruct",
            "name": "Mistral 7B Instruct",
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          },
          {
            "id": "qwen2.5-coder:7b",
            "name": "Qwen 2.5 Coder 7B",
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": [
          "openai/gpt-5.4",
          "anthropic/claude-haiku-4-5",
          "openai/gpt-5.4-nano"
        ]
      },
      "models": {
        "anthropic/claude-opus-4-6": { "alias": "opus" },
        "anthropic/claude-sonnet-4-6": { "alias": "sonnet" },
        "anthropic/claude-haiku-4-5": { "alias": "haiku" },
        "openai/gpt-5.3-codex": { "alias": "codex" },
        "openai/gpt-5.4": { "alias": "gpt54" },
        "openai/gpt-5.4-mini": { "alias": "gpt54mini" },
        "openai/gpt-5.4-nano": { "alias": "gpt54nano" },
        "openrouter/openrouter/auto": { "alias": "auto" },
        "openrouter/anthropic/claude-opus-4.6": { "alias": "oropus" },
        "openrouter/anthropic/claude-sonnet-4.6": { "alias": "orsonnet" },
        "openrouter/anthropic/claude-haiku-4.5": { "alias": "orhaiku" },
        "openrouter/openai/gpt-5.3-codex": { "alias": "orcodex" },
        "ollama/llama3.2:latest": { "alias": "llama" },
        "ollama/mistral:7b-instruct": { "alias": "mistral" },
        "ollama/qwen2.5-coder:7b": { "alias": "qwen" }
      },
      "workspace": "/home/node/.openclaw/workspace",
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "compaction": {
        "mode": "safeguard",
        "memoryFlush": {
          "enabled": true
        }
      },
      "memorySearch": {
        "sources": ["memory", "sessions"],
        "experimental": {
          "sessionMemory": true
        }
      },
      "heartbeat": {
        "every": "30m",
        "model": "ollama/llama3.2:latest"
      },
      "subagents": {
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 5,
        "maxConcurrent": 8,
        "runTimeoutSeconds": 900
      }
    },
    "list": [
      {
        "id": "main",
        "identity": {
          "name": "<your-agent-name>"
        }
      }
    ]
  },
  "tools": {
    "profile": "coding"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groupPolicy": "open",
      "streaming": "partial"
    },
    "discord": {
      "enabled": true,
      "commands": {
        "native": "auto"
      },
      "groupPolicy": "allowlist",
      "streaming": "off",
      "guilds": {
        "<your-guild-id>": {
          "requireMention": false,
          "users": [
            "<your-discord-user-id>"
          ]
        }
      },
      "responsePrefix": "auto",
      "token": "${DISCORD_BOT_TOKEN}"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": ["https://openclaw.YOURHOSTNAME"]
    },
    "auth": {
      "mode": "token",
      "token": "REPLACE_WITH_SECURE_TOKEN"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  }
}
