{
  "meta": {
    "lastTouchedVersion": "2026.3.2",
    "lastTouchedAt": "2026-03-07T19:58:20.656Z"
  },
  "wizard": {
    "lastRunAt": "2026-03-05T18:01:23.657Z",
    "lastRunVersion": "2026.3.2",
    "lastRunCommand": "doctor",
    "lastRunMode": "local"
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "provider": "openrouter",
        "mode": "api_key"
      },
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      },
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "api_key"
      }
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://ollama:11434",
        "apiKey": "ollama-local",
        "api": "ollama",
        "models": [
          {
            "id": "llama3.2:latest",
            "name": "Llama 3.2 3B",
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 8192,
            "maxTokens": 4096
          },
          {
            "id": "mistral:7b-instruct",
            "name": "Mistral 7B Instruct",
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          },
          {
            "id": "qwen2.5-coder:7b",
            "name": "Qwen 2.5 Coder 7B",
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": [
          "anthropic/claude-opus-4-6",
          "ollama/qwen2.5-coder:7b",
          "ollama/mistral:7b-instruct",
          "ollama/llama3.2:latest"
        ]
      },
      "models": {
        "openrouter/openrouter/auto": { "alias": "auto" },
        "openrouter/anthropic/claude-opus-4.6": { "alias": "oropus" },
        "openrouter/anthropic/claude-sonnet-4.6": { "alias": "orsonnet" },
        "openrouter/openai/gpt-5.2": { "alias": "orgpt" },
        "openrouter/openai/gpt-5.2-codex": { "alias": "orcodex" },
        "openrouter/openai/gpt-5-mini": { "alias": "ormini" },
        "anthropic/claude-opus-4-6": { "alias": "opus" },
        "anthropic/claude-sonnet-4-6": { "alias": "sonnet" },
        "openai/gpt-5.2": { "alias": "gpt" },
        "openai/gpt-5.2-codex": { "alias": "codex" },
        "openai/gpt-5-mini": { "alias": "mini" },
        "ollama/llama3.2:latest": { "alias": "llama" },
        "ollama/mistral:7b-instruct": { "alias": "mistral" },
        "ollama/qwen2.5-coder:7b": { "alias": "qwen" }
      },
      "workspace": "/home/node/.openclaw/workspace",
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "compaction": {
        "mode": "safeguard",
        "memoryFlush": {
          "enabled": true
        }
      },
      "memorySearch": {
        "experimental": {
          "sessionMemory": true
        },
        "sources": ["memory", "sessions"]
      },
      "heartbeat": {
        "every": "30m",
        "model": "ollama/llama3.2:latest"
      }
    },
    "list": [
      {
        "id": "main",
        "identity": {
          "name": "OpenClaw"
        }
      }
    ]
  },
  "tools": {
    "profile": "coding"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "channels": {
    "telegram": {
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groupPolicy": "open"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": ["https://openclaw.YOURHOSTNAME"]
    },
    "auth": {
      "mode": "token",
      "token": "REPLACE_WITH_SECURE_TOKEN"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  }
}
